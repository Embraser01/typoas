{
  "name": "@typoas/generator",
  "version": "5.0.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/embraser01/typoas",
    "directory": "packages/typoas-generator"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    "require": {
      "types": "./dist/index.d.cts",
      "default": "./dist/index.cjs"
    },
    "import": {
      "types": "./dist/index.d.mts",
      "development": "./src/index.ts",
      "default": "./dist/index.mjs"
    }
  },
  "scripts": {
    "prepack": "pkgroll",
    "test": "vitest",
    "test:types": "tsc --noEmit",
    "generate-identifier-regexp": "tsx ./scripts/generate-identifier-regexp.ts"
  },
  "dependencies": {
    "es-toolkit": "^1.45.1",
    "openapi3-ts": "^4.3.3",
    "typescript": "~5.9.3"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "@types/regenerate": "^1.4.3",
    "@unicode/unicode-9.0.0": "^1.6.16",
    "pkgroll": "^2.27.0",
    "regenerate": "^1.4.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vitest": "^4.1.0"
  },
  "files": [
    "dist"
  ]
}
