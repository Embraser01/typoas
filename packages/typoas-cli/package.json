{
  "name": "@typoas/cli",
  "version": "5.0.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/embraser01/typoas",
    "directory": "packages/typoas-cli"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    "require": {
      "types": "./dist/index.d.cts",
      "default": "./dist/index.cjs"
    },
    "import": {
      "types": "./dist/index.d.mts",
      "development": "./src/index.ts",
      "default": "./dist/index.mjs"
    }
  },
  "bin": {
    "typoas-cli": "./src/bin.ts"
  },
  "scripts": {
    "prepack": "pkgroll",
    "start": "tsx --conditions=development ./src/bin.ts",
    "test:types": "tsc --noEmit"
  },
  "dependencies": {
    "@typoas/generator": "workspace:^",
    "clipanion": "^4.0.0-rc.4",
    "js-yaml": "^4.1.1",
    "prettier": "^3.8.1",
    "typanion": "^3.14.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.12.0",
    "pkgroll": "^2.27.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "bin": {
      "typoas-cli": "./dist/bin.js"
    }
  }
}
